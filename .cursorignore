# =============================================================================
# .cursorignore — carpetas y archivos que el agente no necesita indexar
# Sintaxis compatible con .gitignore
# =============================================================================

# --- Dependencias ---
node_modules/

# --- Secretos y entorno ---
.env
.env.*
!.env.example

# --- Control de versiones e IDE ---
.git/
.idea/
.vscode/
*.code-workspace
.cursor/

# --- Builds, caché y cobertura ---
dist/
build/
coverage/
.cache/
tmp/
temp/

# --- Logs ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- Subidas y contenido dinámico (no código) ---
uploads/
public/uploads/
public/content/
src/public/content/

# --- Imágenes estáticas versionadas (rutas en EJS/CSS; no hace falta leer binarios) ---
src/public/img/

# --- Archivos del sistema ---
.DS_Store
Thumbs.db
desktop.ini
~$*
*.tmp
