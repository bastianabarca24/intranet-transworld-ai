<style>
  /* --- ESTILOS BASE EJECUTIVOS PARA PÁGINAS INTERNAS --- */
  .contenedor { max-width: 600px; margin: 0 auto; padding: 20px; font-family: system-ui, -apple-system, sans-serif; }
  .page-title { color: #003a70; font-size: 1.8rem; font-weight: 800; margin: 0 0 25px 0; border-bottom: 2px solid #003a70; padding-bottom: 10px; }
  
  .link-volver { display: inline-block; background: #f8fafc; border: 1px solid #cbd5e0; color: #4a5568; padding: 8px 15px; border-radius: 6px; text-decoration: none; font-weight: 600; font-size: 0.9rem; transition: all 0.2s; margin-bottom: 20px;}
  .link-volver:hover { background: #edf2f7; color: #1a202c; }
  
  .panel { background: #fff; border: 1px solid #e0e6ed; border-radius: 8px; padding: 25px; box-shadow: 0 2px 8px rgba(0,0,0,0.04); margin-bottom: 25px; }
  
  .form-ticket label { font-weight: 700; color: #4a5568; display: block; margin-bottom: 6px; font-size: 0.95rem; }
  
  /* Agregamos input[type="text"] para que mantenga su estilo cuando el ojo cambia su estado */
  .form-ticket input[type="password"],
  .form-ticket input[type="text"] { width: 100%; padding: 12px; border: 1px solid #cbd5e0; border-radius: 6px; font-size: 0.95rem; background: #f8fafc; margin-bottom: 20px; box-sizing: border-box; transition: all 0.2s; font-family: inherit;}
  
  .form-ticket input[type="password"]:focus,
  .form-ticket input[type="text"]:focus { border-color: #003a70; outline: none; background: #fff; box-shadow: 0 0 0 3px rgba(0, 58, 112, 0.1);}
  
  .btn-primario { background: #003a70; color: #fff; border: none; padding: 12px 24px; border-radius: 6px; font-weight: bold; cursor: pointer; transition: background 0.2s; font-size: 1rem; }
  .btn-primario:hover { background: #002a52; }
  .mensaje-error { color: #e53e3e; background: #fff5f5; border: 1px solid #feb2b2; padding: 12px; border-radius: 6px; font-weight: 600; margin-bottom: 20px; text-align: center;}

  /* --- CONTENEDOR CONTRASEÑA Y OJO --- */
  .password-wrapper { position: relative; display: block; width: 100%; margin-bottom: 20px; }
  .password-wrapper input { margin-bottom: 0 !important; padding-right: 40px !important; }
  .toggle-password {
    position: absolute; right: 12px; top: 0; bottom: 0; margin: auto; cursor: pointer;
    color: #718096; display: flex; align-items: center; justify-content: center;
    width: 22px; height: 22px; transition: color 0.2s;
  }
  .toggle-password:hover { color: #1a202c; }
  .toggle-password svg { width: 100%; height: 100%; }
</style>

<div class="contenedor" style="max-width: 600px; margin: 0 auto;">
  <a href="/perfil" class="link-volver">← Volver al perfil</a>
  
  <h2 class="page-title">Cambiar contraseña</h2>
  
  <% if (locals.error) { %>
    <div class="mensaje-error" style="margin-bottom: 20px;"><%= error %></div>
  <% } %>

  <div class="panel">
    <form action="/change-password" method="POST" class="form-ticket">
      
      <label for="old_password">Contraseña actual</label>
      <div class="password-wrapper">
        <input type="password" id="old_password" name="old_password" required autofocus>
        <span class="toggle-password" onclick="toggleVisibility('old_password', this)" title="Mostrar/Ocultar contraseña">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
        </span>
      </div>

      <label for="new_password">Nueva contraseña</label>
      <div class="password-wrapper">
        <input type="password" id="new_password" name="new_password" required minlength="6">
        <span class="toggle-password" onclick="toggleVisibility('new_password', this)" title="Mostrar/Ocultar contraseña">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
        </span>
      </div>

      <label for="confirm_password">Repetir nueva contraseña</label>
      <div class="password-wrapper">
        <input type="password" id="confirm_password" name="confirm_password" required minlength="6">
        <span class="toggle-password" onclick="toggleVisibility('confirm_password', this)" title="Mostrar/Ocultar contraseña">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
        </span>
      </div>

      <div style="margin-top: 25px; text-align: right;">
        <button type="submit" class="btn btn-primario">Actualizar contraseña</button>
      </div>

    </form>
  </div>
</div>

<script>
  function toggleVisibility(inputId, iconSpan) {
    const input = document.getElementById(inputId);
    if (input.type === 'password') {
      input.type = 'text';
      iconSpan.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23"></line></svg>';
    } else {
      input.type = 'password';
      iconSpan.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>';
    }
  }
</script>