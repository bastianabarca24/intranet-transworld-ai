<style>
  .contenedor { max-width: 1200px; margin: 0 auto; padding: 20px; font-family: system-ui, -apple-system, sans-serif; }
  h2 { color: #003a70; font-size: 2rem; font-weight: 800; margin: 0 0 10px 0; border-bottom: 2px solid #003a70; padding-bottom: 12px; margin-bottom: 25px; }
  p { color: #4a5568; font-size: 1.05rem; margin-bottom: 30px; }

  .grid-opciones { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 25px; }

  .boton-opcion {
    background: #ffffff; border: 1px solid #e2e8f0; border-radius: 12px; padding: 30px 25px;
    text-decoration: none; display: flex; flex-direction: column; align-items: flex-start;
    transition: all 0.3s ease; box-shadow: 0 2px 5px rgba(0,0,0,0.02);
    color: #003a70; font-size: 1.25rem; font-weight: 800;
  }
  
  .boton-opcion:hover {
    transform: translateY(-5px); box-shadow: 0 12px 20px rgba(0,0,0,0.08); border-color: #cbd5e0; background: #f8fafc;
  }
  
  .boton-opcion span { color: #718096; font-size: 0.95rem; font-weight: 400; margin-top: 8px; line-height: 1.5; }
  
  .boton-opcion::before { 
    content: "🎫"; 
    font-size: 1.8rem; 
    margin-bottom: 15px; 
    background: #eef4ff; 
    width: 55px; 
    height: 55px; 
    display: flex; 
    align-items: center; 
    justify-content: center; 
    border-radius: 14px; 
    border: 1px solid #d1e0ff; 
  }
</style>

<div class="contenedor">
  <h2>Sistemas y Herramientas</h2>
  <p>Accesos rápidos a los sistemas principales:</p>

  <div class="grid-opciones">
    <a class="boton-opcion" href="/sistemas/tickets">
      Ticketera
      <span>Creación y seguimiento de tickets de soporte interno.</span>
    </a>
  </div>
</div>