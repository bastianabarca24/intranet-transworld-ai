# Copia este archivo a .env y completa los valores reales.
# Nunca subas .env al repositorio.

# --- Aplicación ---
PORT=3000
# Dominio público actual de la intranet (sin barra final)
APP_BASE_URL=https://tu-dominio-actual.com
# NODE_ENV=production
# TRUST_PROXY=true
SESSION_SECRET=cambiar-por-un-secreto-largo-y-aleatorio

# --- Base de datos (PostgreSQL) ---
# Opción A: variables separadas (local o Supabase)
DB_HOST=localhost
DB_PORT=5432
DB_USER=
DB_PASSWORD=
# DB_PASS=          # alias aceptado por db.js si DB_PASSWORD no está definido
DB_NAME=

# Opción B: connection string (tiene prioridad si está definida)
# Copia el host EXACTO desde Supabase Dashboard → Connect (el cluster puede ser aws-0, aws-1, etc.).
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-1-[region].pooler.supabase.com:5432/postgres

# SSL: obligatorio en Supabase. Se activa solo con DB_SSL=true o si el host/URL es de Supabase.
# DB_SSL=true

# --- Correo (Brevo / SMTP) ---
MAIL_FROM=noreply@transworld.cl
BREVO_API_KEY=
# SMTP_PASS=        # fallback si no usas BREVO_API_KEY

# --- Notificaciones administrativas ---
ADMIN_NOTIFY_EMAIL=

# --- SharePoint / Microsoft Graph ---
MS_CLIENT_ID=
MS_TENANT_ID=
MS_CLIENT_SECRET=
SP_SITE_ID=

# --- LinkedIn (feed en inicio) ---
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# Debe coincidir EXACTAMENTE con una Redirect URL en LinkedIn Developer Portal.
# Si cambiaste de dominio, agrega la URL nueva en el portal y actualiza estas variables.
# Si no se define, se usa APP_BASE_URL + /auth/linkedin/callback
LINKEDIN_CALLBACK_URL=https://tu-dominio-actual.com/auth/linkedin/callback
LINKEDIN_ORG_ID=
# Versión de la Marketing API (formato YYYYMM). Ver: linkedin.com/developers
LINKEDIN_API_VERSION=202601

# --- Email listener (IMAP, script email-listener) ---
IMAP_HOST=outlook.office365.com
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=

# --- Auth legacy (solo si aplica en tu entorno) ---
# AUTH_USER=
# AUTH_PASS=

# --- Claude AI Integration ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx
CLAUDE_DEFAULT_MODEL=claude-haiku-4-5
CLAUDE_MAX_FILE_SIZE=10
# CLAUDE_MAX_DOC_CHARS=120000
